# PostgreSQL connection
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/requisti

# Firebase Admin SDK — download from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=requisti-version
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@requisti-version.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Server
PORT=4000
NODE_ENV=development

# Allowed frontend origin
FRONTEND_ORIGIN=http://localhost:3000
